      m_Calls: []
  m_text: "\u2190 \u2192          Mover a nave\r\nEspa\xE7o       Atirar\r\n\r\nAcerte
    o inimigo com a resposta correta.\r\nOs n\xEDveis possuem ondas e um boss no
    final.\r\n\r\nFase 1: Adi\xE7\xE3o    |   Fase 2: Subtra\xE7\xE3o\r\nFase 3:
    Divis\xE3o   |   Fase 4: Multiplica\xE7\xE3o\r\n\r\nPower-ups:\r\n  Escudo \u2192
    bloqueia 1 erro\r\n  Tempo Lento \u2192 reduz velocidade dos inimigos\r\n\r\nAcerte
    todas as quest\xF5es para avan\xE7ar!"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
